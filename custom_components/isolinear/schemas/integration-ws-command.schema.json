{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/integration-ws-command.schema.json",
  "title": "IntegrationWsCommand",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "type",
        "version",
        "config_entry_id",
        "prompt"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "isolinear/v1/job/start"
        },
        "version": {
          "const": 1
        },
        "config_entry_id": {
          "type": "string",
          "pattern": "\\S"
        },
        "prompt": {
          "type": "string",
          "pattern": "\\S"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "type",
        "version",
        "config_entry_id",
        "job_id",
        "question_id",
        "option_id",
        "remember"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "isolinear/v1/clarification/answer"
        },
        "version": {
          "const": 1
        },
        "config_entry_id": {
          "type": "string",
          "pattern": "\\S"
        },
        "job_id": {
          "type": "string",
          "pattern": "\\S"
        },
        "question_id": {
          "type": "string",
          "pattern": "\\S"
        },
        "option_id": {
          "type": "string",
          "pattern": "\\S"
        },
        "remember": {
          "type": "boolean"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "type",
        "version",
        "config_entry_id",
        "job_id"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "isolinear/v1/job/retry"
        },
        "version": {
          "const": 1
        },
        "config_entry_id": {
          "type": "string",
          "pattern": "\\S"
        },
        "job_id": {
          "type": "string",
          "pattern": "\\S"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "type",
        "version",
        "config_entry_id",
        "job_id"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "isolinear/v1/job/snapshot"
        },
        "version": {
          "const": 1
        },
        "config_entry_id": {
          "type": "string",
          "pattern": "\\S"
        },
        "job_id": {
          "type": "string",
          "pattern": "\\S"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "type",
        "version",
        "config_entry_id",
        "job_id"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "isolinear/v1/job/subscribe"
        },
        "version": {
          "const": 1
        },
        "config_entry_id": {
          "type": "string",
          "pattern": "\\S"
        },
        "job_id": {
          "type": "string",
          "pattern": "\\S"
        }
      }
    }
  ]
}
