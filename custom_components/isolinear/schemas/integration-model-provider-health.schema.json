{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/integration-model-provider-health.schema.json",
  "title": "IntegrationModelProviderHealth",
  "type": "object",
  "required": [
    "health_id",
    "type",
    "config_entry_id",
    "status",
    "code",
    "provider",
    "request",
    "response",
    "validation",
    "warnings",
    "orchestration"
  ],
  "additionalProperties": false,
  "properties": {
    "health_id": {
      "type": "string",
      "pattern": "\\S"
    },
    "type": {
      "const": "isolinear_model_provider_health"
    },
    "config_entry_id": {
      "type": "string",
      "pattern": "\\S"
    },
    "status": {
      "enum": [
        "ready",
        "not_ready",
        "unavailable"
      ]
    },
    "code": {
      "type": "string",
      "pattern": "\\S"
    },
    "provider": {
      "type": "object",
      "required": [
        "type",
        "role",
        "endpoint_url",
        "model",
        "health_path"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "ollama_compatible"
        },
        "role": {
          "const": "planner"
        },
        "endpoint_url": {
          "type": "string",
          "pattern": "^https?://"
        },
        "model": {
          "type": "string",
          "pattern": "\\S"
        },
        "health_path": {
          "const": "/api/tags"
        }
      }
    },
    "request": {
      "type": "object",
      "required": [
        "protocol_version",
        "method",
        "path",
        "headers"
      ],
      "additionalProperties": false,
      "properties": {
        "protocol_version": {
          "const": 1
        },
        "method": {
          "const": "GET"
        },
        "path": {
          "const": "/api/tags"
        },
        "headers": {
          "type": "object",
          "required": [
            "accept"
          ],
          "additionalProperties": false,
          "properties": {
            "accept": {
              "const": "application/json"
            }
          }
        }
      }
    },
    "response": {
      "type": "object",
      "required": [
        "accepted",
        "status",
        "code",
        "message",
        "checks",
        "capabilities"
      ],
      "additionalProperties": false,
      "properties": {
        "accepted": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "ready",
            "not_ready",
            "unavailable"
          ]
        },
        "code": {
          "type": "string",
          "pattern": "\\S"
        },
        "message": {
          "type": "string",
          "pattern": "\\S"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "status"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "\\S"
              },
              "status": {
                "type": "string",
                "pattern": "\\S"
              }
            }
          }
        },
        "capabilities": {
          "type": "object",
          "required": [
            "planning",
            "structured_output"
          ],
          "additionalProperties": false,
          "properties": {
            "planning": {
              "type": "boolean"
            },
            "structured_output": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "status",
        "summary",
        "checks"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "const": "pass"
        },
        "summary": {
          "type": "string",
          "pattern": "\\S"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "status"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "\\S"
              },
              "status": {
                "type": "string",
                "pattern": "\\S"
              }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "orchestration": {
      "type": "object",
      "required": [
        "model_provider_health_check_called",
        "model_provider_health_bookkeeping_written",
        "model_provider_health_request_validated",
        "model_provider_health_response_validated",
        "model_provider_planning_called",
        "model_provider_retry_policy_written",
        "worker_called",
        "worker_health_check_called",
        "home_assistant_history_read",
        "semantic_memory_called",
        "home_assistant_service_or_state_mutation_called",
        "token_generated",
        "token_rotation_called",
        "chart_rendering_called",
        "chart_artifact_written",
        "durable_storage_written",
        "durable_retry_storage_written",
        "retry_behavior_called",
        "scheduler_called",
        "automatic_retry_called",
        "automatic_progress_task_called",
        "new_provider_transport_added",
        "provider_details_leaked_to_card"
      ],
      "additionalProperties": false,
      "properties": {
        "model_provider_health_check_called": {
          "type": "boolean"
        },
        "model_provider_health_bookkeeping_written": {
          "type": "boolean"
        },
        "model_provider_health_request_validated": {
          "type": "boolean"
        },
        "model_provider_health_response_validated": {
          "type": "boolean"
        },
        "model_provider_planning_called": {
          "type": "boolean"
        },
        "model_provider_retry_policy_written": {
          "type": "boolean"
        },
        "worker_called": {
          "type": "boolean"
        },
        "worker_health_check_called": {
          "type": "boolean"
        },
        "home_assistant_history_read": {
          "type": "boolean"
        },
        "semantic_memory_called": {
          "type": "boolean"
        },
        "home_assistant_service_or_state_mutation_called": {
          "type": "boolean"
        },
        "token_generated": {
          "type": "boolean"
        },
        "token_rotation_called": {
          "type": "boolean"
        },
        "chart_rendering_called": {
          "type": "boolean"
        },
        "chart_artifact_written": {
          "type": "boolean"
        },
        "durable_storage_written": {
          "type": "boolean"
        },
        "durable_retry_storage_written": {
          "type": "boolean"
        },
        "retry_behavior_called": {
          "type": "boolean"
        },
        "scheduler_called": {
          "type": "boolean"
        },
        "automatic_retry_called": {
          "type": "boolean"
        },
        "automatic_progress_task_called": {
          "type": "boolean"
        },
        "new_provider_transport_added": {
          "type": "boolean"
        },
        "provider_details_leaked_to_card": {
          "type": "boolean"
        }
      }
    }
  }
}
