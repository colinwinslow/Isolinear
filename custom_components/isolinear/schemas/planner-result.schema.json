{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/planner-result.schema.json",
  "title": "PlannerResult",
  "type": "object",
  "required": [
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "status": {
      "enum": [
        "chart_spec_ready",
        "clarification_needed",
        "cannot_resolve"
      ]
    },
    "chart_spec": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "clarification_question": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "memory_proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "default": []
    },
    "reasoning_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
