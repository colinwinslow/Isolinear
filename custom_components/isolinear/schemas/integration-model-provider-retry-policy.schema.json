{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/integration-model-provider-retry-policy.schema.json",
  "title": "IntegrationModelProviderRetryPolicy",
  "type": "object",
  "required": [
    "policy_id",
    "type",
    "config_entry_id",
    "job_id",
    "source_snapshot_id",
    "provider",
    "request",
    "failure",
    "decision",
    "backoff",
    "validation",
    "warnings"
  ],
  "additionalProperties": false,
  "properties": {
    "policy_id": {
      "type": "string",
      "pattern": "\\S"
    },
    "type": {
      "const": "isolinear_model_provider_retry_policy"
    },
    "config_entry_id": {
      "type": "string",
      "pattern": "\\S"
    },
    "job_id": {
      "type": "string",
      "pattern": "\\S"
    },
    "source_snapshot_id": {
      "type": "string",
      "pattern": "\\S"
    },
    "provider": {
      "type": "object",
      "required": [
        "type",
        "role",
        "endpoint_url",
        "model"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "ollama_compatible"
        },
        "role": {
          "const": "planner"
        },
        "endpoint_url": {
          "type": "string",
          "pattern": "^https?://"
        },
        "model": {
          "type": "string",
          "pattern": "\\S"
        }
      }
    },
    "request": {
      "type": "object",
      "required": [
        "prompt",
        "approved_entity_ids",
        "history_entity_ids",
        "output_schema"
      ],
      "additionalProperties": false,
      "properties": {
        "prompt": {
          "type": "string"
        },
        "approved_entity_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "\\S"
          }
        },
        "history_entity_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "\\S"
          }
        },
        "output_schema": {
          "const": "PlannerResult"
        }
      }
    },
    "failure": {
      "type": "object",
      "required": [
        "stage",
        "code",
        "message",
        "retry_safe"
      ],
      "additionalProperties": false,
      "properties": {
        "stage": {
          "const": "model_provider_planning"
        },
        "code": {
          "type": "string",
          "pattern": "\\S"
        },
        "message": {
          "type": "string",
          "pattern": "\\S"
        },
        "retry_safe": {
          "type": "boolean"
        }
      }
    },
    "decision": {
      "type": "object",
      "required": [
        "eligible",
        "reason",
        "manual_retry_allowed",
        "automatic_retry_scheduled"
      ],
      "additionalProperties": false,
      "properties": {
        "eligible": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "pattern": "\\S"
        },
        "manual_retry_allowed": {
          "type": "boolean"
        },
        "automatic_retry_scheduled": {
          "const": false
        }
      }
    },
    "backoff": {
      "type": "object",
      "required": [
        "strategy",
        "attempt_number",
        "delay_seconds",
        "max_delay_seconds",
        "jitter_applied"
      ],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "const": "bounded_exponential_scaffold"
        },
        "attempt_number": {
          "type": "integer",
          "minimum": 1
        },
        "delay_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 60
        },
        "max_delay_seconds": {
          "const": 60
        },
        "jitter_applied": {
          "const": false
        }
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "status",
        "summary",
        "checks"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "const": "pass"
        },
        "summary": {
          "type": "string",
          "pattern": "\\S"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "status"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "\\S"
              },
              "status": {
                "type": "string",
                "pattern": "\\S"
              }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
