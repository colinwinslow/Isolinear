{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/clarification-question.schema.json",
  "title": "ClarificationQuestion",
  "type": "object",
  "required": [
    "question_id",
    "message",
    "options"
  ],
  "additionalProperties": false,
  "properties": {
    "question_id": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "option_id",
          "label",
          "value"
        ],
        "additionalProperties": false,
        "properties": {
          "option_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "value": {
            "type": "object",
            "additionalProperties": true
          },
          "can_remember": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "allow_free_text": {
      "type": "boolean",
      "default": false
    }
  }
}
