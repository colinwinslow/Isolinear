{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/chart-spec.schema.json",
  "title": "ChartSpec",
  "type": "object",
  "required": [
    "chart_id",
    "chart_type",
    "title",
    "time_range",
    "series"
  ],
  "additionalProperties": false,
  "properties": {
    "chart_id": {
      "type": "string"
    },
    "chart_type": {
      "enum": [
        "time_series",
        "bar",
        "heatmap",
        "histogram",
        "scatter",
        "timeline",
        "multi_panel"
      ]
    },
    "title": {
      "type": "string"
    },
    "time_range": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type",
            "duration"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "relative"
            },
            "duration": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "start",
            "end"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "absolute"
            },
            "start": {
              "type": "string",
              "format": "date-time"
            },
            "end": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      ]
    },
    "series": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "series_id",
          "label",
          "source",
          "role"
        ],
        "additionalProperties": false,
        "properties": {
          "series_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "source": {
            "$ref": "#/$defs/sourceRef"
          },
          "role": {
            "enum": [
              "primary",
              "comparison",
              "secondary",
              "annotation"
            ]
          },
          "render_as": {
            "enum": [
              "line",
              "step",
              "bar",
              "heatmap",
              "histogram",
              "scatter",
              "area"
            ],
            "default": "line"
          },
          "transform": {
            "$ref": "#/$defs/transform"
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "overlays": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": [
          "overlay_id",
          "label",
          "source",
          "render_as"
        ],
        "additionalProperties": false,
        "properties": {
          "overlay_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "source": {
            "$ref": "#/$defs/sourceRef"
          },
          "render_as": {
            "enum": [
              "shaded_intervals",
              "markers",
              "band",
              "step"
            ]
          },
          "active_values": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "number",
                "boolean"
              ]
            }
          },
          "color_map": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "threshold": {
            "$ref": "#/$defs/threshold"
          }
        }
      }
    },
    "x_axis": {
      "type": "object",
      "additionalProperties": true,
      "default": {
        "type": "time"
      }
    },
    "y_axis": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "$defs": {
    "sourceRef": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type",
            "entity_id"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "entity"
            },
            "entity_id": {
              "type": "string"
            },
            "attribute": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "alias_id"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "alias"
            },
            "alias_id": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "entity_ids",
            "operation"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "aggregate"
            },
            "entity_ids": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "operation": {
              "enum": [
                "mean",
                "min",
                "max",
                "sum",
                "count"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "entity_id",
            "operation"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "aggregate"
            },
            "entity_id": {
              "type": "string"
            },
            "attribute": {
              "type": ["string", "null"]
            },
            "operation": {
              "enum": [
                "mean",
                "min",
                "max",
                "sum",
                "count"
              ]
            }
          }
        }
      ]
    },
    "threshold": {
      "type": "object",
      "required": [
        "operator",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "operator": {
          "enum": [
            ">",
            ">=",
            "<",
            "<=",
            "==",
            "!="
          ]
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "transform": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "operation": {
          "enum": [
            "none",
            "rolling_mean",
            "resample_mean",
            "resample_sum",
            "difference"
          ]
        },
        "window": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
