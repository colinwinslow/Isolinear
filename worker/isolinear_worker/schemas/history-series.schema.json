{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/history-series.schema.json",
  "title": "HistorySeries",
  "type": "object",
  "required": [
    "series_id",
    "label",
    "kind"
  ],
  "additionalProperties": false,
  "properties": {
    "series_id": {
      "type": "string"
    },
    "entity_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "label": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "numeric",
        "binary_state",
        "categorical_state",
        "event"
      ]
    },
    "unit": {
      "type": [
        "string",
        "null"
      ]
    },
    "points": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": [
          "ts"
        ],
        "additionalProperties": false,
        "properties": {
          "ts": {
            "type": "string",
            "format": "date-time"
          },
          "value": {
            "type": [
              "number",
              "string",
              "boolean",
              "null"
            ]
          },
          "value_min": {
            "type": [
              "number",
              "null"
            ]
          },
          "value_max": {
            "type": [
              "number",
              "null"
            ]
          },
          "raw_state": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          },
          "quality": {
            "enum": [
              "ok",
              "unknown",
              "unavailable",
              "invalid",
              "missing"
            ]
          },
          "attrs": {
            "type": "object",
            "description": "Selected entity attributes captured at each state change, keyed by attribute name. Used for categorical overlays that shade by attribute value rather than entity state (e.g. hvac_action for climate entities)."
          }
        }
      }
    },
    "source": {
      "enum": [
        "recorder_states",
        "long_term_statistics"
      ]
    },
    "resolution": {
      "enum": [
        "raw",
        "hourly",
        "daily"
      ]
    },
    "source_entity_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
