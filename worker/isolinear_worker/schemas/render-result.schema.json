{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/render-result.schema.json",
  "title": "RenderResult",
  "type": "object",
  "required": [
    "request_id",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "success",
        "failed"
      ]
    },
    "image_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "image_mime_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "image_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "image_bytes_base64": {
      "type": [
        "string",
        "null"
      ],
      "contentEncoding": "base64",
      "maxLength": 2667000
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "render_metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ],
          "description": "Model-authored chart summary copied from chart_spec.summary (ADR-0027). Surfaced as the card caption."
        },
        "series_plotted": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "overlays_plotted": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "x_min": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "x_max": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "codegen_attempts": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "legend": {
          "type": "array",
          "description": "Color manifest: one entry per drawn series/overlay, the single source of truth for legend colors (ADR-0027 D1). Present for time_series and time_series_overlay families.",
          "items": {
            "type": "object",
            "required": [
              "label",
              "entity_id",
              "color",
              "kind"
            ],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string"
              },
              "entity_id": {
                "type": "string"
              },
              "color": {
                "type": "string",
                "pattern": "^#[0-9a-fA-F]{6}$"
              },
              "kind": {
                "enum": [
                  "series",
                  "overlay"
                ]
              },
              "states": {
                "type": "array",
                "description": "Per-state band colors for an overlay row (omitted for series).",
                "items": {
                  "type": "object",
                  "required": [
                    "label",
                    "color"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "label": {
                      "type": "string"
                    },
                    "color": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    }
                  }
                }
              }
            }
          },
          "default": []
        }
      },
      "default": {}
    }
  }
}
